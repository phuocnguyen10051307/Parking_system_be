{
  "openapi": "3.0.3",
  "info": {
    "title": "Parking Management Auth API",
    "version": "1.0.0",
    "description": "Authentication API documentation."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current API host"
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "System endpoints"
    },
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "Buildings",
      "description": "Building management endpoints"
    },
    {
      "name": "Users",
      "description": "User management endpoints"
    },
    {
      "name": "Vehicles",
      "description": "Vehicle management endpoints"
    }
  ],
  "paths": {
    "/v1/status": {
      "get": {
        "tags": ["System"],
        "summary": "Check API status",
        "responses": {
          "200": {
            "description": "API is running",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "message": "APIs V1 are ready to use."
                }
              }
            }
          }
        }
      }
    },

    "/v1/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },

    "/v1/auth/signin": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in with email and password",
        "description": "Returns an access token and sets a refreshToken cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SigninRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed in successfully",
            "headers": {
              "Set-Cookie": {
                "description": "HTTP-only refresh token cookie",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SigninResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },

    "/v1/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current authenticated user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },

    "/v1/auth/signout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign out",
        "security": [
          {
            "refreshTokenCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Signed out successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    },

    "/v1/auth/refresh-token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "security": [
          {
            "refreshTokenCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Access token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessTokenResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/v1/admin/buildings": {
      "get": {
        "tags": ["Buildings"],
        "summary": "Get all buildings",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Buildings retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Building"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["Buildings"],
        "summary": "Create a new building",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuildingRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Building created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Building created successfully"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Building"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },

    "/v1/admin/buildings/{id}": {
      "put": {
        "tags": ["Buildings"],
        "summary": "Update a building",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "cmc8h2x3z0000abc123xyz"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuildingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Building updated successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "description": "Building not found"
          }
        }
      },
      "delete": {
        "tags": ["Buildings"],
        "summary": "Delete a building",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "cmc8h2x3z0000abc123xyz"
          }
        ],
        "responses": {
          "200": {
            "description": "Building deleted successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "description": "Building not found"
          }
        }
      }
    },
    "/v1/users/profile": {
      "get": {
        "tags": ["Users"],
        "summary": "Get current user profile",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user profile"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update current user profile",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },

    "/v1/users/change-password": {
      "put": {
        "tags": ["Users"],
        "summary": "Change current user password",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password changed successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/vehicles": {
  "get": {
    "tags": ["Vehicles"],
    "summary": "Get vehicles",
    "description": "Get list of vehicles. Normal users can only see their own vehicles. Staff/Admin can see all vehicles.",
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "parameters": [
      {
        "name": "vehicleType",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["MOTORBIKE", "CAR", "BICYCLE", "ELECTRIC_BIKE"]
        },
        "example": "MOTORBIKE"
      },
      {
        "name": "ownerId",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Optional. Used by staff/admin to filter vehicles by owner.",
        "example": "cmqxuser123"
      }
    ],
    "responses": {
      "200": {
        "description": "Get vehicles successfully",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/VehicleListResponse"
            }
          }
        }
      },
      "401": {
        "$ref": "#/components/responses/Unauthorized"
      }
    }
  },
  "post": {
    "tags": ["Vehicles"],
    "summary": "Create vehicle",
    "description": "Create a new vehicle for the current user. Staff/Admin can create vehicle for another user by providing ownerId.",
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/CreateVehicleRequest"
          }
        }
      }
    },
    "responses": {
      "201": {
        "description": "Create vehicle successfully",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/VehicleResponse"
            }
          }
        }
      },
      "400": {
        "$ref": "#/components/responses/BadRequest"
      },
      "401": {
        "$ref": "#/components/responses/Unauthorized"
      },
      "404": {
        "$ref": "#/components/responses/NotFound"
      }
    }
  }
},
"/v1/vehicles/{id}": {
  "get": {
    "tags": ["Vehicles"],
    "summary": "Get vehicle by id",
    "description": "Get detail of a vehicle by id.",
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "cmqxvehicle123"
      }
    ],
    "responses": {
      "200": {
        "description": "Get vehicle successfully",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/VehicleResponse"
            }
          }
        }
      },
      "401": {
        "$ref": "#/components/responses/Unauthorized"
      },
      "404": {
        "$ref": "#/components/responses/NotFound"
      }
    }
  },
  "put": {
    "tags": ["Vehicles"],
    "summary": "Update vehicle",
    "description": "Update vehicle information by id.",
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "cmqxvehicle123"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/UpdateVehicleRequest"
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "Update vehicle successfully",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/VehicleResponse"
            }
          }
        }
      },
      "400": {
        "$ref": "#/components/responses/BadRequest"
      },
      "401": {
        "$ref": "#/components/responses/Unauthorized"
      },
      "404": {
        "$ref": "#/components/responses/NotFound"
      }
    }
  },
  "delete": {
    "tags": ["Vehicles"],
    "summary": "Delete vehicle",
    "description": "Delete vehicle by id.",
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "cmqxvehicle123"
      }
    ],
    "responses": {
      "200": {
        "description": "Delete vehicle successfully",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MessageResponse"
            }
          }
        }
      },
      "401": {
        "$ref": "#/components/responses/Unauthorized"
      },
      "404": {
        "$ref": "#/components/responses/NotFound"
      }
    }
  }
}
  },

  "components": {
    "schemas": {
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },

      "SignupRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Nguyen Van A"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@gmail.com"
          },
          "phone": {
            "type": "string",
            "example": "0987654321"
          },
          "password": {
            "type": "string",
            "example": "Password123"
          }
        },
        "required": ["fullName", "email", "password"]
      },

      "SigninRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "Password123"
          }
        },
        "required": ["email", "password"]
      },

      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "cmc8h2x3z0000abc123xyz"
          },
          "fullName": {
            "type": "string",
            "example": "Nguyen Van A"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@gmail.com"
          },
          "phone": {
            "type": "string",
            "nullable": true,
            "example": "0987654321"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/avatar.jpg"
          },
          "role": {
            "type": "string",
            "example": "USER"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },

      "SigninResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "User Nguyen Van A signed in successfully"
          },
          "accessToken": {
            "type": "string"
          }
        }
      },

      "AccessTokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          }
        }
      },
      "BuildingRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Building A"
          },
          "address": {
            "type": "string",
            "example": "FPT University HCM"
          },
          "totalFloors": {
            "type": "integer",
            "example": 5
          }
        },
        "required": ["name", "address", "totalFloors"]
      },

      "Building": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "cmc8h2x3z0000abc123xyz"
          },
          "name": {
            "type": "string",
            "example": "Building A"
          },
          "address": {
            "type": "string",
            "example": "FPT University HCM"
          },
          "totalFloors": {
            "type": "integer",
            "example": 5
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "_count": {
            "type": "object",
            "properties": {
              "floors": {
                "type": "integer",
                "example": 3
              }
            }
          }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Tran Minh Quan"
          },
          "phone": {
            "type": "string",
            "example": "0987654321"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/avatar.jpg"
          }
        }
      },

      "ChangePasswordRequest": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "example": "Password123"
          },
          "newPassword": {
            "type": "string",
            "example": "NewPassword123"
          }
        },
        "required": ["currentPassword", "newPassword"]
      },
      "Vehicle": {
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "cmqxvehicle123"
    },
    "ownerId": {
      "type": "string",
      "example": "cmqxuser123"
    },
    "licensePlate": {
      "type": "string",
      "example": "59A1-12345"
    },
    "vehicleType": {
      "type": "string",
      "enum": ["MOTORBIKE", "CAR", "BICYCLE", "ELECTRIC_BIKE"],
      "example": "MOTORBIKE"
    },
    "brand": {
      "type": "string",
      "example": "Honda"
    },
    "color": {
      "type": "string",
      "example": "Black"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "example": "2026-06-16T10:00:00.000Z"
    },
    "owner": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "cmqxuser123"
        },
        "fullName": {
          "type": "string",
          "example": "Tran Minh Quan"
        },
        "email": {
          "type": "string",
          "example": "quan001@test.com"
        },
        "phone": {
          "type": "string",
          "example": "0987654321"
        }
      }
    }
  }
},
"CreateVehicleRequest": {
  "type": "object",
  "required": ["licensePlate", "vehicleType"],
  "properties": {
    "ownerId": {
      "type": "string",
      "description": "Optional. Staff/Admin can create vehicle for another user.",
      "example": "cmqxuser123"
    },
    "licensePlate": {
      "type": "string",
      "example": "59A1-12345"
    },
    "vehicleType": {
      "type": "string",
      "enum": ["MOTORBIKE", "CAR", "BICYCLE", "ELECTRIC_BIKE"],
      "example": "MOTORBIKE"
    },
    "brand": {
      "type": "string",
      "example": "Honda"
    },
    "color": {
      "type": "string",
      "example": "Black"
    }
  }
},
"UpdateVehicleRequest": {
  "type": "object",
  "properties": {
    "licensePlate": {
      "type": "string",
      "example": "59A1-67890"
    },
    "vehicleType": {
      "type": "string",
      "enum": ["MOTORBIKE", "CAR", "BICYCLE", "ELECTRIC_BIKE"],
      "example": "MOTORBIKE"
    },
    "brand": {
      "type": "string",
      "example": "Yamaha"
    },
    "color": {
      "type": "string",
      "example": "Red"
    }
  }
},
"VehicleResponse": {
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean",
      "example": true
    },
    "message": {
      "type": "string",
      "example": "Tạo phương tiện thành công"
    },
    "data": {
      "$ref": "#/components/schemas/Vehicle"
    }
  }
},
"VehicleListResponse": {
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean",
      "example": true
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Vehicle"
      }
    }
  }
}
    },

    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MessageResponse"
            }
          }
        }
      },

      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MessageResponse"
            }
          }
        }
      },

      "Forbidden": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": {
